FOXSAY_ENV=development

# DeepSeek LLM (OpenAI 兼容, base_url 见 https://api-docs.deepseek.com/)
DEEPSEEK_API_KEY=replace-with-local-dev-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Embedding API (OpenAI 兼容, 默认用 SiliconFlow 跑 bge-m3)
EMBEDDING_API_KEY=replace-with-embedding-api-key
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

# Qdrant 向量存储
#   留空 = 进程内 local mode (数据持久化到 ./data/qdrant_storage, 无需 Docker, 默认)
#   填 http://host:port = 远程模式 (Qdrant 单独容器/服务器)
QDRANT_URL=

# Qdrant local mode 持久化目录 (仅当 QDRANT_URL 留空时生效)
QDRANT_LOCAL_PATH=./data/qdrant_storage

# Knowledge System V2 persistent jobs (course-level compile budget; worker wiring is staged)
KNOWLEDGE_JOB_DEFAULT_TOKEN_BUDGET=12000

# Judge LLM (PR0 新增,评测端 / 轻量分类端使用)
# 必须跟 DEEPSEEK_MODEL 不同家族 (调研结论:防 self-preference bias)。
# 默认指向 LM Studio 本地 Qwen3.5 9B (OpenAI 兼容,默认端口 1234)。
# 用途:DeepEval Judge / 题库质检 / prereq 二审 / cognitive_dimension 分类。
JUDGE_API_KEY=lm-studio
JUDGE_API_BASE=http://localhost:1234/v1
JUDGE_MODEL_NAME=qwen/qwen3.5-9b
# Fast judge: 非 reasoning, 大批量轻活用 (5 选 1 分类 / JSON 格式校验)
JUDGE_FAST_MODEL_NAME=qwen/qwen3-4b-2507
# Reranker: NLI 蕴含判定, 评测 v2 ALiiCE 用 (免装 BGE-reranker)
RERANKER_MODEL_NAME=qwen3-reranker-0.6b
